<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".activities.MainFragmentManagerActivity">

    <TextClock
        android:id="@+id/clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:format12Hour="h:mm:ss a"
        android:format24Hour="H:mm:ss"
        android:layout_gravity="center"
        android:textSize="20sp"
        android:gravity="center"
        android:visibility="gone"
        tools:text="4:15 PM"/>

    <TextView
        android:id="@+id/shabbat_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:padding="5dp"
        android:scrollHorizontally="true"
        tools:text="SHABBAT/CHAG MODE                SHABBAT/CHAG MODE               SHABBAT/CHAG MODE           SHABBAT/CHAG MODE             SHABBAT/CHAG MODE"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@color/darkblue"
        android:gravity="center"
        android:visibility="gone"
        tools:ignore="HardcodedText" />

    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmerLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:shimmer_auto_start="true"
        tools:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/dummyRV"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constrainedHeight="true" />

    </com.facebook.shimmer.ShimmerFrameLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/daily_location_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-light"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMaxTextSize="22sp"
                    android:autoSizeMinTextSize="8sp"
                    android:maxLines="1"
                    android:padding="4dp"
                    tools:ignore="UnusedAttribute" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/daily_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_marginVertical="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/weekday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:maxLines="1"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMaxTextSize="20sp"
                            android:autoSizeMinTextSize="8sp"
                            tools:text="Friday / יום שישי"/>

                        <TextView
                            android:id="@+id/top_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:textSize="26sp"
                            android:maxLines="1"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMaxTextSize="26sp"
                            android:autoSizeMinTextSize="8sp"
                            tools:text="Today - July 10th, 2025"/>

                        <TextView
                            android:id="@+id/bottom_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:textSize="20sp"
                            android:maxLines="1"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMaxTextSize="20sp"
                            android:autoSizeMinTextSize="8sp"
                            tools:text="Pre-sunset: 14 Ḥeshvan 5785"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/parsha_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_marginVertical="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/parsha"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:textSize="24sp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:maxLines="1"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMaxTextSize="24sp"
                            android:autoSizeMinTextSize="8sp"
                            tools:text="דברים / חזון"
                            android:fontFamily="@font/vilna"/>

                        <LinearLayout
                            android:id="@+id/haftara_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/haftara"
                                android:textSize="20sp"
                                android:src="@drawable/megila_icon"
                                android:text="@string/haftara"/>

                            <TextView
                                android:id="@+id/haftara"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="20sp"
                                android:paddingStart="5dp"
                                android:layout_gravity="center"
                                android:maxLines="1"
                                android:autoSizeTextType="uniform"
                                android:autoSizeMaxTextSize="20sp"
                                android:autoSizeMinTextSize="8sp"
                                tools:text="Haftarah: חזון (ישעיה א)"/>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/makam_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:baselineAligned="true">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="match_parent"
                                android:src="@drawable/u1f3bc__1_"
                                android:text="@string/haftara"
                                android:textSize="20sp" />

                            <TextView
                                android:id="@+id/makam"
                                android:paddingStart="5dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="20sp"
                                android:layout_gravity="center"
                                android:autoSizeTextType="uniform"
                                android:autoSizeMaxTextSize="20sp"
                                android:autoSizeMinTextSize="8sp"
                                tools:text="Makam: Rast"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chanuka_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_marginVertical="10dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/night_of_chanuka"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:maxLines="1"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMaxTextSize="20sp"
                            android:autoSizeMinTextSize="8sp"
                            app:drawableEndCompat="@drawable/baseline_local_fire_department_24"
                            tools:text="Chanuka - Night 1" />

                        <TextView
                            android:id="@+id/lchatchila_lighting_time"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="28sp"
                            android:gravity="center"
                            android:maxLines="1"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMaxTextSize="20sp"
                            android:autoSizeMinTextSize="8sp"
                            tools:text="Ideal: 4:41 PM - 5:11 PM"/>

                        <TextView
                            android:id="@+id/full_window_lighting_time"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:maxLines="1"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMaxTextSize="26sp"
                            android:autoSizeMinTextSize="8sp"
                            tools:text="Earliest: 3:38 PM - Latest: 6:32 AM"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/mainRV"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:focusable="true"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:descendantFocusability="afterDescendants"
                    app:layout_constrainedHeight="true"
                    android:visibility="visible"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <LinearLayout
        android:id="@+id/date_buttons"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:layoutDirection="ltr"
        tools:ignore="TooManyViews">

        <Button
            android:id="@+id/prev_day"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:padding="1dp"
            android:backgroundTint="?android:attr/colorBackground"
            android:contentDescription="@string/left"
            android:drawableLeft="@drawable/baseline_arrow_back_24"
            style="?android:attr/button" />

        <Button
            android:id="@+id/calendar"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:backgroundTint="@color/dark_blue"
            android:contentDescription="@string/change_date"
            style="?android:attr/button" />

        <Button
            android:id="@+id/next_day"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:padding="1dp"
            android:backgroundTint="?android:attr/colorBackground"
            android:contentDescription="@string/right"
            android:drawableEnd="@drawable/baseline_arrow_forward_24"
            style="?android:attr/button" />

    </LinearLayout>

</LinearLayout>
