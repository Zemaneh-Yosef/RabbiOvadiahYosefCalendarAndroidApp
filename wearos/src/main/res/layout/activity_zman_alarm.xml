<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- Timer icon — tinted with app accent gold -->
    <ImageView
        android:id="@+id/alarm_icon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="64dp"
        android:contentDescription="@string/next_zman_complication_label"
        android:src="@drawable/outline_alarm_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Zman name — white, bold, up to two lines for long Hebrew names -->
    <TextView
        android:id="@+id/zman_name_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/alarm_icon" />

    <!-- Zman time — large gold display, the focal point of the screen -->
    <TextView
        android:id="@+id/zman_time_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="#C6AA14"
        android:textSize="64sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/zman_name_text" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="120dp"
        android:layout_height="1dp"
        android:layout_marginTop="32dp"
        android:background="#33FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/zman_time_text" />

    <!-- Dismiss button — anchored to the bottom so it is easy to tap -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/dismiss_button"
        style="@style/Widget.Material3.Button"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:layout_marginBottom="80dp"
        android:text="@string/alarm_dismiss"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="#C6AA14"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
